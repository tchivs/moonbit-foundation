import {
  "tchivs/mb-core/error",
  "tchivs/mb-core/checked",
  "tchivs/mb-core/budget",
  "tchivs/mb-core/math",
  "tchivs/mb-color/model" @color,
  "tchivs/mb-color/quantize",
  "tchivs/mb-color/alpha",
  "tchivs/mb-color/blend",
  "tchivs/mb-color/profile",
  "tchivs/mb-image/model" @imgmodel,
  "tchivs/mb-image/metadata",
  "tchivs/mb-image/storage",
}

supported_targets = "+js+wasm+wasm-gc+native"

warnings = "-29-35"
