{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tchivs/moonbit-foundation/release/qualification/phase-08-authorization-receipt-schema.json",
  "title": "Phase 8 literal core mutation authorization receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_ref", "boundary_sha", "source_sha", "packet_sha256", "historical_attempt_zero_sha256", "historical_r1_sha256", "historical_r2_sha256", "historical_history_set_sha256", "response", "created_at_utc", "receipt_sha256"],
  "properties": {
    "schema_version": { "const": "mnf-phase08-authorization-receipt/1" },
    "release_ref": { "const": "refs/tags/modules-v0.1.0-r3" },
    "boundary_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "packet_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "historical_attempt_zero_sha256": { "const": "b9bda5378ea339f4cdd42c417c1cc0cf8caabbd51ab11d453cd45ddae77d9b52" },
    "historical_r1_sha256": { "const": "cba047dae2e6b4e1bbf0248653ed7848f144971b54a0a4ed30ef42ab97325653" },
    "historical_r2_sha256": { "const": "aae8bee66e7dbfca7f3f22f1b52071e7888ae3ec8feee513d1c5d8eba6111609" },
    "historical_history_set_sha256": { "const": "f04b431490910eb7da8125a09c5575ea0b9f0138708bb14b8f36834ea038185c" },
    "response": { "const": "authorize-core" },
    "created_at_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "receipt_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
