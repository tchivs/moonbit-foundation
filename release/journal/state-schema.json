{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonbit-foundation.invalid/schemas/release-journal-state-1.json",
  "title": "MNF monotonic publisher state vocabulary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "states", "observation_statuses", "outcomes"],
  "properties": {
    "schema_version": { "const": "mnf-release-journal-state/1" },
    "states": {
      "const": ["intent_authorized", "preflight_passed", "core_mutation_attempted", "core_registry_observed", "core_checkpoint_verified", "color_mutation_attempted", "color_registry_observed", "color_checkpoint_verified", "image_mutation_attempted", "image_registry_observed", "image_checkpoint_verified", "handoff_ready", "terminal_mismatch", "stopped_absent", "stopped_unknown", "stopped_invalid_auth"]
    },
    "observation_statuses": { "const": ["not_observed", "absent", "exact_match", "mismatch", "unknown"] },
    "outcomes": { "const": ["accepted", "mutation_pending_observation", "checkpoint_verified", "idempotent_checkpoint", "fresh_authorization_required", "incident_opened", "unknown_stopped", "authentication_rejected", "handoff_ready"] }
  }
}
