{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonbit-foundation.invalid/schemas/release-prepared-1.json",
  "title": "MNF secret-free prepared publisher bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "actor", "run_id", "run_attempt", "release_ref", "source_sha", "root_intent_sha256", "intent_sha256", "intent_kind", "correction_sequence", "predecessor_intent_sha256", "run_mode", "journal_binding", "toolchain", "payloads"],
  "properties": {
    "schema_version": { "const": "mnf-release-prepared/1" },
    "repository": { "const": "tchivs/moonbit-foundation" },
    "actor": { "const": "tchivs" },
    "run_id": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "run_attempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "release_ref": { "type": "string", "pattern": "^refs/tags/modules-(v0[.]1[.]0-r10|correction-[1-9][0-9]*)$" },
    "source_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "root_intent_sha256": { "$ref": "#/$defs/sha256" },
    "intent_sha256": { "$ref": "#/$defs/sha256" },
    "intent_kind": { "enum": ["initial", "forward_correction"] },
    "correction_sequence": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
    "predecessor_intent_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "run_mode": { "enum": ["start", "resume"] },
    "journal_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "prior_run_id", "prior_artifact_name", "terminal_record_sha256"],
      "properties": {
        "kind": { "enum": ["genesis", "verified_prior_chain"] },
        "prior_run_id": { "type": ["string", "null"], "pattern": "^[1-9][0-9]*$" },
        "prior_artifact_name": { "type": ["string", "null"], "pattern": "^mnf-checkpoint-[a-z0-9-]+$" },
        "terminal_record_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      }
    },
    "toolchain": {
      "type": "object", "additionalProperties": false,
      "required": ["moon", "moonc", "moonrun"],
      "properties": {
        "moon": { "const": "0.1.20260713 (75c7e1f 2026-07-13)" },
        "moonc": { "const": "v0.10.4+2cc641edf (2026-07-15)" },
        "moonrun": { "const": "0.1.20260713 (75c7e1f 2026-07-13)" }
      }
    },
    "payloads": {
      "type": "array", "minItems": 11,
      "items": { "$ref": "#/$defs/payload" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "payload": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "role", "size", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^(?![./])(?!.*(?:^|/)[.][.]?(?:/|$))[a-zA-Z0-9_.-]+(?:/[a-zA-Z0-9_.-]+)*$" },
        "role": { "enum": ["exact_source_archive", "current_intent", "current_intent_digest", "initial_root_intent_evidence", "journal_or_genesis", "publisher_script", "publisher_common", "release_policy", "contract_schema", "qualification_evidence", "archive_interface_digests", "sanitized_authority_observation"] },
        "size": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
