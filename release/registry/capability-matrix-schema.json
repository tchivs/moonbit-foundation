{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonbit-foundation.invalid/schemas/registry-capability-matrix-1.0.0.json",
  "title": "MNF registry capability matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_commit", "observed_at_utc", "capabilities", "stable_sha256", "run_local"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "observed_at_utc": { "type": ["string", "null"], "format": "date-time" },
    "capabilities": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/capability" }
    },
    "stable_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "run_local": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_by", "completed_utc"],
      "properties": {
        "generated_by": { "const": "tracked_seed" },
        "completed_utc": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "source", "required_for_publish", "disposition"],
      "properties": {
        "id": { "enum": ["cli_surfaces", "namespace_authority", "token_lifecycle", "dry_run_fidelity", "exact_version_availability", "version_immutability", "registry_propagation", "artifact_identity", "destructive_recovery", "registry_render_metadata"] },
        "state": { "enum": ["documented", "safely_observed", "unknown"] },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reference"],
          "properties": {
            "kind": { "enum": ["project_policy", "official_documentation", "authenticated_read_only_registry", "not_observed"] },
            "reference": { "type": "string", "minLength": 1, "maxLength": 160 }
          }
        },
        "required_for_publish": { "type": "boolean" },
        "disposition": { "enum": ["allow", "block_publication", "require_read_only_query", "forward_only_recovery"] }
      }
    }
  }
}
