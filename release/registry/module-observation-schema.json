{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tchivs/moonbit-foundation/release/registry/module-observation-schema.json",
  "title": "Sanitized Mooncakes Module Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_sha256",
    "identity",
    "version",
    "outcome",
    "reason",
    "terminal_disposition",
    "mutation_authorized",
    "attempt_count",
    "started_at_utc",
    "completed_at_utc",
    "surfaces",
    "content_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "policy_sha256": { "$ref": "#/$defs/sha256" },
    "identity": { "type": "string", "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "outcome": { "enum": ["exact", "absent", "mismatch", "unknown"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 160 },
    "terminal_disposition": { "enum": ["exact_match", "confirmed_absent", "mismatch_incident", "timeout_unknown", "observation_unknown"] },
    "mutation_authorized": { "const": false },
    "attempt_count": { "type": "integer", "minimum": 1, "maximum": 20 },
    "started_at_utc": { "type": "string", "format": "date-time" },
    "completed_at_utc": { "type": "string", "format": "date-time" },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/surface" }
    },
    "observed": { "$ref": "#/$defs/observed" },
    "content_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "classification", "attempt", "observed_at_utc"],
      "properties": {
        "name": { "enum": ["publish_preflight", "authenticated_account", "public_user", "public_module", "registry_index", "archive", "downloaded_manifest", "versioned_assets"] },
        "classification": { "enum": ["exact", "absent", "mismatch", "unknown"] },
        "attempt": { "type": "integer", "minimum": 1, "maximum": 20 },
        "observed_at_utc": { "type": "string", "format": "date-time" }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "version"],
      "properties": {
        "identity": { "type": "string", "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "description", "license", "repository", "readme", "preferred-target", "supported-targets"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "license": { "type": "string" },
        "repository": { "type": "string" },
        "readme": { "type": "string" },
        "preferred-target": { "type": "string" },
        "supported-targets": { "type": "string" }
      }
    },
    "graphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity"],
      "properties": {
        "identity": { "type": "string" }
      }
    },
    "graphEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/graphNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/graphEdge" } }
      }
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata", "dependencies", "public_packages", "targets", "graph", "manifest_sha256", "readme_sha256", "archive_sha256"],
      "properties": {
        "metadata": { "$ref": "#/$defs/metadata" },
        "dependencies": { "type": "array", "items": { "$ref": "#/$defs/dependency" } },
        "public_packages": { "type": "array", "items": { "type": "string" } },
        "targets": { "type": "array", "items": { "enum": ["js", "wasm", "wasm-gc", "native"] } },
        "graph": { "$ref": "#/$defs/graph" },
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "readme_sha256": { "$ref": "#/$defs/sha256" },
        "archive_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
