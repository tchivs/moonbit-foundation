{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonbit-foundation.invalid/schemas/release-intent-1.json",
  "title": "MNF immutable release intent",
  "oneOf": [
    { "$ref": "#/$defs/initialIntent" },
    { "$ref": "#/$defs/forwardCorrectionIntent" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sourceSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["moon", "moonc", "moonrun"],
      "properties": {
        "moon": { "const": "0.1.20260713 (75c7e1f 2026-07-13)" },
        "moonc": { "const": "v0.10.4+2cc641edf (2026-07-15)" },
        "moonrun": { "const": "0.1.20260713 (75c7e1f 2026-07-13)" }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "version"],
      "properties": {
        "identity": { "enum": ["tchivs/mb-core", "tchivs/mb-color"] },
        "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "identity", "version", "dependencies", "public_packages", "archive_sha256", "interface_sha256"],
      "properties": {
        "module": { "enum": ["mb-core", "mb-color", "mb-image"] },
        "identity": { "enum": ["tchivs/mb-core", "tchivs/mb-color", "tchivs/mb-image"] },
        "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
        "dependencies": { "type": "array", "maxItems": 2, "items": { "$ref": "#/$defs/dependency" } },
        "public_packages": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^tchivs/mb-(core|color|image)/[a-z][a-z0-9_-]*$" }, "uniqueItems": true },
        "archive_sha256": { "$ref": "#/$defs/sha256" },
        "interface_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualification_root_sha256", "required_stable_sha256", "phase_06_ledger_sha256", "release_policy_sha256", "compatibility_policy_sha256"],
      "properties": {
        "qualification_root_sha256": { "$ref": "#/$defs/sha256" },
        "required_stable_sha256": { "$ref": "#/$defs/sha256" },
        "phase_06_ledger_sha256": { "$ref": "#/$defs/sha256" },
        "release_policy_sha256": { "$ref": "#/$defs/sha256" },
        "compatibility_policy_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "correctionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["superseded_intent_sha256", "incident_sha256", "advisory_sha256", "compatibility_result_sha256", "version_absence_sha256"],
      "properties": {
        "superseded_intent_sha256": { "$ref": "#/$defs/sha256" },
        "incident_sha256": { "$ref": "#/$defs/sha256" },
        "advisory_sha256": { "$ref": "#/$defs/sha256" },
        "compatibility_result_sha256": { "$ref": "#/$defs/sha256" },
        "version_absence_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "initialIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "intent_kind", "repository", "owner", "release_ref", "source_sha", "correction_sequence", "toolchain", "modules", "evidence", "tracked_source_clean", "credentials_read", "publication_performed"],
      "properties": {
        "schema_version": { "const": "mnf-release-intent/1" },
        "intent_kind": { "const": "initial" },
        "repository": { "const": "tchivs/moonbit-foundation" },
        "owner": { "const": "tchivs" },
        "release_ref": { "const": "refs/tags/modules-v0.1.0-r2" },
        "source_sha": { "$ref": "#/$defs/sourceSha" },
        "correction_sequence": { "const": 0 },
        "toolchain": { "$ref": "#/$defs/toolchain" },
        "modules": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/module" } },
        "evidence": { "$ref": "#/$defs/evidence" },
        "tracked_source_clean": { "const": true },
        "credentials_read": { "const": false },
        "publication_performed": { "const": false }
      }
    },
    "forwardCorrectionIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "intent_kind", "repository", "owner", "release_ref", "source_sha", "root_intent_sha256", "predecessor_intent_sha256", "correction_sequence", "toolchain", "modules", "evidence", "correction_evidence", "tracked_source_clean", "credentials_read", "publication_performed"],
      "properties": {
        "schema_version": { "const": "mnf-release-intent/1" },
        "intent_kind": { "const": "forward_correction" },
        "repository": { "const": "tchivs/moonbit-foundation" },
        "owner": { "const": "tchivs" },
        "release_ref": { "type": "string", "pattern": "^refs/tags/modules-correction-[1-9][0-9]*$" },
        "source_sha": { "$ref": "#/$defs/sourceSha" },
        "root_intent_sha256": { "$ref": "#/$defs/sha256" },
        "predecessor_intent_sha256": { "$ref": "#/$defs/sha256" },
        "correction_sequence": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "toolchain": { "$ref": "#/$defs/toolchain" },
        "modules": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/module" } },
        "evidence": { "$ref": "#/$defs/evidence" },
        "correction_evidence": { "$ref": "#/$defs/correctionEvidence" },
        "tracked_source_clean": { "const": true },
        "credentials_read": { "const": false },
        "publication_performed": { "const": false }
      }
    }
  }
}
