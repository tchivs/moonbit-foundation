{
  "schema_version": "1.0.0",
  "dependency_source": "registry_only",
  "module_order": [
    "mb-core",
    "mb-color",
    "mb-image"
  ],
  "required_targets": [
    "js",
    "wasm",
    "wasm-gc",
    "native"
  ],
  "metadata_fields": [
    "name",
    "version",
    "description",
    "license",
    "repository",
    "readme",
    "preferred-target",
    "supported-targets"
  ],
  "package_inventory_order": [
    "mb-core",
    "mb-color",
    "mb-image"
  ],
  "surface_order": [
    "publish_preflight",
    "authenticated_account",
    "public_user",
    "public_module",
    "registry_index",
    "archive",
    "downloaded_manifest",
    "versioned_assets"
  ],
  "surface_classifications": [
    "exact",
    "absent",
    "mismatch",
    "unknown"
  ],
  "polling": {
    "interval_seconds": 15,
    "max_attempts": 20,
    "states": [
      "pending",
      "exact",
      "absent",
      "mismatch",
      "timeout",
      "unknown"
    ]
  },
  "terminal_dispositions": [
    "exact_match",
    "confirmed_absent",
    "mismatch_incident",
    "timeout_unknown",
    "observation_unknown"
  ],
  "mutation_authority": false,
  "strongest_identity": {
    "algorithm": "sha256",
    "registry_prefix": "sha256:",
    "require_archive_agreement": true,
    "weaker_identity_disposition": "observation_unknown"
  },
  "redaction": {
    "reject_unknown_fields": true,
    "persist_raw_responses": false,
    "forbidden_field_names": [
      "authorization",
      "cookie",
      "credentials",
      "password",
      "raw_body",
      "secret",
      "token"
    ],
    "forbidden_value_patterns": [
      "(?i)authorization\\s*:",
      "(?i)bearer\\s+",
      "(?i)(token|secret|password|cookie)\\s*[:=]",
      "(?i)(credentials?|cookies?)\\.(json|txt|db)",
      "(?i)[A-Z]:\\\\Users\\\\[^\\\\]+\\\\"
    ]
  },
  "graph": {
    "nodes": [
      { "identity": "tchivs/mb-core@0.1.0" },
      { "identity": "tchivs/mb-color@0.1.0" },
      { "identity": "tchivs/mb-image@0.1.0" }
    ],
    "edges": [
      { "from": "tchivs/mb-color@0.1.0", "to": "tchivs/mb-core@0.1.0" },
      { "from": "tchivs/mb-image@0.1.0", "to": "tchivs/mb-core@0.1.0" },
      { "from": "tchivs/mb-image@0.1.0", "to": "tchivs/mb-color@0.1.0" }
    ]
  },
